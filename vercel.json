{
    "routes": [
        {
            "src": "^/$",
            "has": [
                {
                    "type": "host",
                    "value": "stream.mfadhilfadholi.my.id"
                }
            ],
            "dest": "/stream"
        },
        {
            "src": "^/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "stream.mfadhilfadholi.my.id"
                }
            ],
            "dest": "/stream/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ]
}