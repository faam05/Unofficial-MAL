{
    "rewrites": [
        {
            "source": "/",
            "has": [
                {
                    "type": "host",
                    "value": "stream.mfadhilfadholi.my.id"
                }
            ],
            "destination": "/stream"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "stream.mfadhilfadholi.my.id"
                }
            ],
            "destination": "/stream/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ],
    "cleanUrls": true,
    "framework": "vite",
    "installCommand": "npm install"
}