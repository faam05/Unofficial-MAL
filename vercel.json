{
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ],
    "routes": [
        {
            "src": "^/stream$",
            "status": 301,
            "headers": {
                "Location": "https://stream.mfadhilfadholi.my.id"
            }
        },
        {
            "src": "^/stream/(.*)",
            "status": 301,
            "headers": {
                "Location": "https://stream.mfadhilfadholi.my.id/$1"
            }
        }
    ],
    "cleanUrls": true,
    "framework": "vite",
    "installCommand": "npm install"
}