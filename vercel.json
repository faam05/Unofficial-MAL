{
    "routes": [
        {
            "src": "^/(.*)",
            "has": [
                {
                    "type": "host",
                    "value": "stream.mfadhilfadholi.my.id"
                }
            ],
            "dest": "/stream/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/.*",
            "dest": "/index.html"
        }
    ]
}